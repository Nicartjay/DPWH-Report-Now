{
  "name": "dpwh-report-now",
  "version": "1.0.0",
  "description": "DPWH Report Now - Mobile-first web app for browsing and reporting DPWH infrastructure projects",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "keywords": [
    "dpwh",
    "infrastructure",
    "reporting",
    "philippines"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "next": "^16.2.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "wrangler": "^4.96.0"
  }
}
